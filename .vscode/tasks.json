{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Spring Boot App",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "package"],
            "group": "build",
            "problemMatcher": ["$tsc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run Spring Boot App",
            "type": "shell",
            "command": "mvn",
            "args": ["spring-boot:run"],
            "group": "none",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
